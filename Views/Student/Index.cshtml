@model List<Student>
@{
    ViewData["Title"] = "Öğrenciler";
}

@if(ViewBag.Error!=null){
    <div class="row">
        <div class="col-md-12">
            <p class="text-error">@ViewBag.Error</p>
        </div>
    </div>

}
@if(TempData["Mesaj"]!=null){
    <div class="row">
        <div class="col-md-12">
            <p class="text-error">@TempData["Mesaj"]</p>
        </div>
    </div>

}




@if (Model.Any())
{
    foreach (var item in Model)
    {
        <div class="row mt-3">
            <div class="col-md-4">
                <img class="img-fluid" src="~/images/@item.Photo" />
            </div>
            <div class="col-md-4">
                <h3 class="card-title">@item.Name</h3>
                <p class="card-text">@item.Surname</p>
            </div>
                
            <div class="col-md-4">
                <a asp-action="Detail" asp-controller="Student" class="btn btn-success" asp-route-id="@item.Id">Detay</a>
                <button class="btn btn-danger" onclick="ogrenciSil(@item.Id)">Sil</button>
            </div>
        </div>
        <div class="text-success"><hr /></div>
    }
}
else
{
    <div class="row">
        <div class="col-12">
            <h3 class="text-info">Kayıtlı Öğrenci yok</h3>
        </div>
    </div>
}

@section Scripts{

<script>
    function ogrenciSil(x){
        if(confirm("Öğrenciyi silcenmi ?")){
            document.location="/Student/Delete/"+x;
        }

    }

</script>


}